{
  "name": "aie-os-cli",
  "version": "0.1.0",
  "description": "CLI for building and delivering AIE OS agent context",
  "license": "UNLICENSED",
  "packageManager": "pnpm@10.8.1",
  "bin": {
    "aie-os": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "build-agent-context.sh",
    "build-cli-pkg.sh",
    "init-aie-os.sh"
  ],
  "scripts": {
    "compile": "tsc -p tsconfig.json",
    "build": "pnpm install && pnpm compile",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "tsc -p tsconfig.json && node --test tests/*.test.js"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "typescript": "^5.8.2"
  }
}
